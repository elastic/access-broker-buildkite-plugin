#!/usr/bin/env bash

set -euo pipefail

plugin_name="access-broker"
default_audience="elastic-access-broker"
default_oidc_claims="organization_slug,pipeline_id,pipeline_slug,build_id,build_branch,build_commit,cluster_id,queue_id,queue_key,step_key,job_id"
default_oidc_lifetime="300"
default_curl_timeout_seconds="30"
access_broker_gate_response_file=""

log() {
  printf '%s\n' "$*" >&2
}

fail() {
  log "access-broker: $*"
  exit 1
}

config_get() {
  local var_name="BUILDKITE_PLUGIN_ACCESS_BROKER_$1"
  printf '%s' "${!var_name:-}"
}

normalize_repository() {
  local raw="$1"

  raw="${raw%.git}"
  raw="${raw#git@github.com:}"
  raw="${raw#ssh://git@github.com/}"
  raw="${raw#https://github.com/}"
  raw="${raw#http://github.com/}"
  raw="${raw#git://github.com/}"

  if [[ ! "$raw" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]]; then
    return 1
  fi

  printf '%s' "$raw"
}

require_command() {
  local command_name="$1"
  if ! command -v "$command_name" >/dev/null 2>&1; then
    fail "required command not found: $command_name"
  fi
}

request_oidc_token() {
  local audience="$1"
  local claims="$2"
  local lifetime="$3"

  buildkite-agent oidc request-token \
    --audience "$audience" \
    --lifetime "$lifetime" \
    --claim "$claims"
}

post_verification_request() {
  local broker_url="$1"
  local token="$2"
  local body="$3"
  local timeout_seconds="$4"
  local response_file="$5"

  curl \
    --silent \
    --show-error \
    --max-time "$timeout_seconds" \
    --output "$response_file" \
    --write-out '%{http_code}' \
    --header "Authorization: Bearer $token" \
    --header "Content-Type: application/json" \
    --data "$body" \
    "$broker_url"
}

require_allow_verdict() {
  local response_file="$1"

  if grep -Eq '"verdict"[[:space:]]*:[[:space:]]*"allow"' "$response_file"; then
    return
  fi

  log "access-broker: Access Broker did not return an allow verdict"
  sed -n '1,40p' "$response_file" >&2
  exit 1
}

main() {
  require_command buildkite-agent
  require_command curl
  require_command grep
  require_command sed
  require_command mktemp

  local broker_url
  local configured_repository
  local repository_source
  local repository
  local pull_request
  local branch
  local audience
  local oidc_claims
  local oidc_lifetime
  local curl_timeout_seconds
  local token
  local request_body
  local response_file
  local status

  broker_url="$(config_get "BROKER_URL")"
  [[ -n "$broker_url" ]] || fail "broker-url is required"

  configured_repository="$(config_get "REPOSITORY")"
  repository_source="${configured_repository:-${BUILDKITE_REPO:-}}"
  [[ -n "$repository_source" ]] || fail "repository is required when BUILDKITE_REPO is not set"
  repository="$(normalize_repository "$repository_source")" || fail "could not normalize repository $repository_source"

  audience="$(config_get "AUDIENCE")"
  audience="${audience:-$default_audience}"

  oidc_claims="$(config_get "OIDC_CLAIMS")"
  oidc_claims="${oidc_claims:-$default_oidc_claims}"

  oidc_lifetime="$(config_get "OIDC_LIFETIME")"
  oidc_lifetime="${oidc_lifetime:-$default_oidc_lifetime}"
  if [[ ! "$oidc_lifetime" =~ ^[0-9]+$ || "$oidc_lifetime" -le 0 ]]; then
    fail "oidc-lifetime must be a positive integer"
  fi

  curl_timeout_seconds="$(config_get "CURL_TIMEOUT_SECONDS")"
  curl_timeout_seconds="${curl_timeout_seconds:-$default_curl_timeout_seconds}"
  if [[ ! "$curl_timeout_seconds" =~ ^[0-9]+$ || "$curl_timeout_seconds" -le 0 ]]; then
    fail "curl-timeout-seconds must be a positive integer"
  fi

  pull_request="${BUILDKITE_PULL_REQUEST:-}"
  if [[ -z "$pull_request" || "$pull_request" == "false" ]]; then
    branch="${BUILDKITE_BRANCH:-}"
    if [[ -z "$branch" ]]; then
      log "access-broker: BUILDKITE_BRANCH is not set, skipping gate"
      exit 0
    fi
    # Derive the head owner from BUILDKITE_REPO so fork PRs are found correctly.
    # For fork builds BUILDKITE_REPO points to the fork, not the base repository.
    local head_repo head_owner
    head_repo="$(normalize_repository "${BUILDKITE_REPO:-}")" || head_repo=""
    head_owner="${head_repo%%/*}"
    log "--- :lock: Verifying pull request gate"
    log "access-broker: repository=$repository branch=$branch head_owner=${head_owner:-<base>}"
    request_body="$(printf '{"repository":"%s","branch":"%s","head_owner":"%s"}' "$repository" "$branch" "$head_owner")"
  else
    if [[ ! "$pull_request" =~ ^[0-9]+$ ]]; then
      fail "BUILDKITE_PULL_REQUEST must be a positive integer, got $pull_request"
    fi
    log "--- :lock: Verifying pull request gate"
    log "access-broker: repository=$repository pull_request=$pull_request"
    request_body="$(printf '{"repository":"%s","pull_request":%s}' "$repository" "$pull_request")"
  fi

  token="$(request_oidc_token "$audience" "$oidc_claims" "$oidc_lifetime")"
  [[ -n "$token" ]] || fail "failed to request Buildkite OIDC token"

  response_file="$(mktemp "${TMPDIR:-/tmp}/${plugin_name}.response.XXXXXX")"
  access_broker_gate_response_file="$response_file"
  trap 'rm -f "${access_broker_gate_response_file:-}"' EXIT

  if ! status="$(post_verification_request "$broker_url" "$token" "$request_body" "$curl_timeout_seconds" "$response_file")"; then
    log "access-broker: Access Broker request failed"
    sed -n '1,40p' "$response_file" >&2 || true
    exit 1
  fi

  if [[ ! "$status" =~ ^2[0-9][0-9]$ ]]; then
    log "access-broker: Access Broker returned HTTP $status"
    sed -n '1,40p' "$response_file" >&2
    exit 1
  fi

  require_allow_verdict "$response_file"
  log "access-broker: allow verdict received"
}

main "$@"
