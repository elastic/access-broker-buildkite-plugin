#!/usr/bin/env bash

set -euo pipefail

default_audience="elastic-access-broker"
default_oidc_claims="organization_slug,pipeline_id,pipeline_slug,build_id,build_branch,build_commit,cluster_id,queue_id,queue_key,step_key,job_id"
default_oidc_lifetime="300"
default_curl_timeout_seconds="30"

log() {
  printf '%s\n' "$*" >&2
}

fail() {
  log "access-broker: $*"
  exit 1
}

config_get() {
  local var="BUILDKITE_PLUGIN_ACCESS_BROKER_$1"
  printf '%s' "${!var:-}"
}

normalize_repository() {
  local raw="$1"
  raw="${raw%.git}"
  raw="${raw#git@github.com:}"
  raw="${raw#ssh://git@github.com/}"
  raw="${raw#https://github.com/}"
  raw="${raw#http://github.com/}"
  raw="${raw#git://github.com/}"
  [[ "$raw" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]] || return 1
  printf '%s' "$raw"
}

main() {
  command -v buildkite-agent >/dev/null || fail "buildkite-agent not found"
  command -v curl >/dev/null || fail "curl not found"

  local broker_url
  broker_url="$(config_get BROKER_URL)"
  [[ -n "$broker_url" ]] || fail "broker-url is required"

  local repo_source
  repo_source="$(config_get REPOSITORY)"
  repo_source="${repo_source:-${BUILDKITE_REPO:-}}"
  [[ -n "$repo_source" ]] || fail "repository is required when BUILDKITE_REPO is not set"

  local repository
  repository="$(normalize_repository "$repo_source")" || fail "could not normalize repository: $repo_source"

  local audience
  audience="$(config_get AUDIENCE)"
  audience="${audience:-$default_audience}"

  local oidc_claims
  oidc_claims="$(config_get OIDC_CLAIMS)"
  oidc_claims="${oidc_claims:-$default_oidc_claims}"

  local oidc_lifetime
  oidc_lifetime="$(config_get OIDC_LIFETIME)"
  oidc_lifetime="${oidc_lifetime:-$default_oidc_lifetime}"
  [[ "$oidc_lifetime" =~ ^[1-9][0-9]*$ ]] || fail "oidc-lifetime must be a positive integer"

  local curl_timeout_seconds
  curl_timeout_seconds="$(config_get CURL_TIMEOUT_SECONDS)"
  curl_timeout_seconds="${curl_timeout_seconds:-$default_curl_timeout_seconds}"
  [[ "$curl_timeout_seconds" =~ ^[1-9][0-9]*$ ]] || fail "curl-timeout-seconds must be a positive integer"

  local request_body
  local pull_request="${BUILDKITE_PULL_REQUEST:-}"
  log "--- :lock: Verifying pull request gate"
  if [[ -z "$pull_request" || "$pull_request" == "false" ]]; then
    local branch="${BUILDKITE_BRANCH:-}"
    if [[ -z "$branch" ]]; then
      log "access-broker: BUILDKITE_BRANCH is not set, skipping gate"
      exit 0
    fi
    log "access-broker: repository=$repository branch=$branch"
    request_body="$(printf '{"repository":"%s","branch":"%s"}' "$repository" "$branch")"
  else
    [[ "$pull_request" =~ ^[0-9]+$ ]] || fail "BUILDKITE_PULL_REQUEST must be a positive integer, got $pull_request"
    log "access-broker: repository=$repository pull_request=$pull_request"
    request_body="$(printf '{"repository":"%s","pull_request":%s}' "$repository" "$pull_request")"
  fi

  local token
  token="$(buildkite-agent oidc request-token \
    --audience "$audience" \
    --lifetime "$oidc_lifetime" \
    --claim "$oidc_claims")"

  local response_file
  response_file="$(mktemp)"
  trap "rm -f '$response_file'" EXIT

  local status
  status="$(curl \
    --silent \
    --show-error \
    --max-time "$curl_timeout_seconds" \
    --output "$response_file" \
    --write-out '%{http_code}' \
    --header "Authorization: Bearer $token" \
    --header "Content-Type: application/json" \
    --data "$request_body" \
    "$broker_url")" || { log "access-broker: $(cat "$response_file")"; exit 1; }

  [[ "$status" =~ ^2 ]] || { log "access-broker: HTTP $status — $(cat "$response_file")"; exit 1; }

  grep -q '"verdict":"allow"' "$response_file" || { log "access-broker: $(cat "$response_file")"; exit 1; }
  log "access-broker: $(cat "$response_file")"
}

main "$@"
